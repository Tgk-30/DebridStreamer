# Copy to .env and change before exposing the service.
PORT=43110

# Public DNS name used by docker-compose.caddy.yml.
YAWF_DOMAIN=stream.example.com

# Generate with:
#   openssl rand -base64 32
DS_SERVER_SECRET_KEY=

# Optional fixed first-run token. When blank, the server generates a token and
# prints it to the container log while owner setup is required.
# Generate with:
#   openssl rand -base64 24
DS_SERVER_SETUP_TOKEN=

# Comma-separated browser origins allowed to call the API with cookies.
# Usually leave blank when the server also serves the web app.
# For a separately bundled desktop app, include its Tauri origin and use
# DS_SERVER_COOKIE_SAMESITE=none over HTTPS.
DS_SERVER_CORS_ORIGIN=

# Set true behind a trusted reverse proxy that terminates HTTPS.
DS_SERVER_COOKIE_SECURE=false
DS_SERVER_COOKIE_SAMESITE=lax
DS_SERVER_TRUST_PROXY=false

# Public mode requires every household viewer profile to have a password.
DS_SERVER_PUBLIC_MODE=false

# Optional defense: invalidate a session if its browser User-Agent changes.
DS_SERVER_BIND_SESSION_USER_AGENT=false

# Session lifetime in seconds. Default is 30 days.
DS_SERVER_SESSION_TTL_SECONDS=2592000

# Let admins see whether a newer server release is available.
DS_SERVER_UPDATE_CHECK=true

# Set only when intentionally binding plain HTTP to every interface on a
# private network without a trusted reverse proxy.
DS_SERVER_ALLOW_INSECURE_PUBLIC=false

# Raw stream sessions are useful for development/testing. Keep disabled in public deployments.
DS_SERVER_ALLOW_RAW_STREAM_URLS=false

# Browser compatibility fallback. Incompatible MKV/HEVC/AV1 sources are served
# as H.264/AAC HLS; browser-compatible MP4/WebM sources remain direct. Set false
# on CPU-constrained hosts that cannot transcode video.
DS_SERVER_ENABLE_TRANSCODE=true
DS_SERVER_MAX_TRANSCODES=1
