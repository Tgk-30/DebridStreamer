{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ds-tauri-poc",
  "version": "0.1.0",
  "identifier": "com.tgk30.ds-tauri-poc",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DebridStreamer - Tauri player POC",
        "width": 1100,
        "height": 780
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https: http: ws: wss:; media-src 'self' https: http: blob:; img-src 'self' https: http: data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
